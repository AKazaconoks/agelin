          { "kind": "regex", "pattern": "(does\\s+not\\s+(modify|update|change)\\s+(the\\s+)?(lock|package-lock))", "flags": "i" },
          { "kind": "regex", "pattern": "(deletes|removes|wipes|clean)\\s+node_modules", "flags": "i" },
