        ]
      },
      {
        "kind": "any-of",
        "assertions": [
          { "kind": "regex", "pattern": "PUT\\s+(is\\s+)?idempotent", "flags": "i" },
          { "kind": "regex", "pattern": "(multiple|repeated|same)\\s+PUT(\\s+requests?)?\\s+(produce|result\\s+in|leave)\\s+(the\\s+)?same\\s+(state|result|effect)", "flags": "i" },
          { "kind": "regex", "pattern": "(safe|safer)\\s+to\\s+(retry|repeat)", "flags": "i" }
        ]
      },
      {
        "kind": "any-of",
        "assertions": [
          { "kind": "regex", "pattern": "POST\\s+(is\\s+)?(not\\s+idempotent|non[- ]?idempotent)", "flags": "i" },
          { "kind": "regex", "pattern": "POST.*creates?\\s+(a\\s+)?new\\s+resource", "flags": "i" },
          { "kind": "regex", "pattern": "(repeated\\s+POST|each\\s+POST)\\s+(creates?|may\\s+create)\\s+(a\\s+)?new", "flags": "i" }
