{
  "id": "so-927358-undo-git-commit",
  "category": "case-study",
  "source_url": "https://stackoverflow.com/questions/927358/how-do-i-undo-the-most-recent-local-commits-in-git",
  "title": "How do I undo the most recent local commits in Git?",
  "prompt": "I accidentally committed the wrong files to Git, but didn't push the commit to the server yet.\n\nHow can I undo those commits from the local repository? Walk me through the relevant `git` command(s) and explain what each one does to the working tree, the staging area, and the commit history. If there are different choices depending on whether I want to KEEP the changes I committed (just unstage them) versus DISCARD them entirely, cover both.",
  "assertion": {
    "kind": "all-of",
    "assertions": [
      {
        "kind": "any-of",
        "assertions": [
          { "kind": "regex", "pattern": "git\\s+reset", "flags": "i" }
        ]
      },
      {
        "kind": "any-of",
        "assertions": [
          { "kind": "regex", "pattern": "--soft", "flags": "" },
          { "kind": "regex", "pattern": "--mixed", "flags": "" },
          { "kind": "regex", "pattern": "--hard", "flags": "" }
        ]
      },
      {
        "kind": "any-of",
        "assertions": [
          { "kind": "regex", "pattern": "HEAD\\^|HEAD~1?|HEAD~\\d+", "flags": "" }
        ]
      },
      {
        "kind": "any-of",
        "assertions": [
          { "kind": "regex", "pattern": "(keep|preserve|retain)\\s+(the\\s+)?(changes|files|work)", "flags": "i" },
          { "kind": "regex", "pattern": "(staged|staging\\s+area|index)", "flags": "i" },
          { "kind": "regex", "pattern": "(working\\s+(tree|directory|copy))", "flags": "i" }
        ]
      }
    ]
  },
  "budget": { "maxTokens": 3500, "maxCostUsd": 0.04, "maxDurationSec": 60, "maxToolCalls": 2 }
}
