# Third-party agent corpora pulled for benchmarking / calibration. These live
# locally for tests but are NOT redistributed in this repo (they have their
# own upstreams: VoltAgent / 0xfurai / lst97 / iannuttall). Re-fetch with
# `npm run fetch-targets` or by cloning each upstream.
targets/
targets-fix-test/
calibration/agents/
calibration/agents-extended/
calibration/cycle5-agents/
calibration/fix-stress/

# Tool output dirs (cache, last-run snapshot, baseline state)
.agelin/

# npm lockfile — this project is bun-first; bun.lock is the lockfile
# of record. package-lock.json gets regenerated by users who prefer npm
# but should not be committed (see CONTRIBUTING.md).
package-lock.json

# Internal R&D artifacts (status logs, personal-machine paths, scratch
# planning docs). Kept locally for the maintainer; not for public consumption.
STATUS.md
QUESTIONS-FOR-USER.md
calibration/cycles/
launch/wild-population-static-scan.json

# VS Code extension build artifacts. The .vsix is produced by
# `editor/vscode/npm run package`; treat it like a build output, not source.
editor/vscode/out/
editor/vscode/*.vsix
editor/vscode/node_modules/
